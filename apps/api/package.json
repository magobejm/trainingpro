{
  "name": "@trainerpro/api",
  "private": true,
  "version": "0.0.1",
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@google/genai": "^1.42.0",
    "@nestjs/common": "^11.0.3",
    "@nestjs/core": "^11.0.3",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.1.13",
    "@prisma/client": "^6.16.3",
    "class-validator": "^0.14.3",
    "express": "^5.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "jose": "^6.1.0",
    "multer": "^2.0.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.13",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.19.11",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "prisma": "^6.16.3",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.1",
    "tsx": "^4.20.5"
  },
  "scripts": {
    "dev": "pnpm exec tsx watch src/main.ts",
    "start:dev": "pnpm run dev",
    "start": "pnpm exec node dist/main.js",
    "db:generate": "pnpm exec prisma generate --schema ../../prisma/schema.prisma",
    "db:migrate:deploy": "pnpm exec prisma migrate deploy --schema ../../prisma/schema.prisma",
    "db:migrate:resolve": "pnpm exec prisma migrate resolve --schema ../../prisma/schema.prisma",
    "db:migrate:status": "pnpm exec prisma migrate status --schema ../../prisma/schema.prisma",
    "db:seed": "pnpm exec tsx prisma/seed.ts",
    "lint": "pnpm exec eslint src --ext .ts",
    "test": "pnpm exec jest --config jest.config.cjs --runInBand",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "build": "pnpm exec tsc -p tsconfig.build.json"
  }
}
