{
  "name": "trainerpro-fitcoach-v1",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev:api": "pnpm --filter @trainerpro/api dev",
    "dev:web": "pnpm --filter @trainerpro/web dev",
    "dev:webapi": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-dev.ps1",
    "dev:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/stop-dev.ps1",
    "dev:status": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/status-dev.ps1",
    "dev:mobile": "pnpm --dir apps/mobile dev",
    "dev:all": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Start-Process pnpm -ArgumentList '--filter','@trainerpro/api','dev' -WorkingDirectory '.'; Start-Process pnpm -ArgumentList '--filter','@trainerpro/web','dev' -WorkingDirectory '.'; Start-Process pnpm -ArgumentList '--filter','@trainerpro/mobile','dev' -WorkingDirectory '.'\"",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build",
    "format": "prettier --check .",
    "prepare": "husky || exit 0"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.89.0",
    "@nestjs/common": "^11.0.3",
    "@nestjs/core": "^11.0.3",
    "@prisma/client": "^6.16.3",
    "@supabase/supabase-js": "^2.57.4",
    "i18next": "^24.2.2",
    "jose": "^6.1.0",
    "react": "^19.0.0",
    "react-i18next": "^15.4.1",
    "react-native": "^0.77.0",
    "zustand": "^5.0.8",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prisma": "^6.16.3",
    "prettier": "^3.5.0",
    "typescript": "^5.7.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ]
  }
}