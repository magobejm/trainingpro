model Incident {
  id                String             @id @default(uuid()) @db.Uuid
  organizationId    String             @map("organization_id") @db.Uuid
  coachMembershipId String             @map("coach_membership_id") @db.Uuid
  clientId          String             @map("client_id") @db.Uuid
  sessionId         String?            @map("session_id") @db.Uuid
  sessionItemId     String?            @map("session_item_id") @db.Uuid
  severity          IncidentSeverity   @default(MEDIUM)
  status            IncidentStatus     @default(OPEN)
  description       String
  tag               String?            @db.VarChar(60)
  coachResponse     String?            @map("coach_response")
  adjustmentDraft   String?            @map("adjustment_draft")
  coachAlertedAt    DateTime?          @map("coach_alerted_at") @db.Timestamptz(6)
  reviewedAt        DateTime?          @map("reviewed_at") @db.Timestamptz(6)
  archivedAt        DateTime?          @map("archived_at") @db.Timestamptz(6)
  createdBy         String             @map("created_by") @db.Uuid
  updatedBy         String             @map("updated_by") @db.Uuid
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  coachMembership   OrganizationMember @relation(fields: [coachMembershipId], references: [id], onDelete: Restrict)
  client            Client             @relation(fields: [clientId], references: [id], onDelete: Restrict)
  session           SessionInstance?   @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  sessionItem       SessionStrengthItem? @relation(fields: [sessionItemId], references: [id], onDelete: SetNull)
  actions           IncidentAction[]

  @@index([coachMembershipId, status, createdAt], map: "idx_incident_coach_status_created")
  @@index([clientId, createdAt], map: "idx_incident_client_created")
  @@index([sessionId], map: "idx_incident_session")
  @@map("incident")
}

