  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  coachMembership   OrganizationMember @relation("coach_chat_threads", fields: [coachMembershipId], references: [id], onDelete: Restrict)
  client            Client             @relation("client_chat_threads", fields: [clientId], references: [id], onDelete: Restrict)
  messages          ChatMessage[]

  @@unique([coachMembershipId, clientId], map: "uq_chat_thread_coach_client")
  @@index([clientId, updatedAt], map: "idx_chat_thread_client_updated")
  @@index([coachMembershipId, updatedAt], map: "idx_chat_thread_coach_updated")
  @@map("chat_thread")
}

model ChatMessage {
  id            String            @id @default(uuid()) @db.Uuid
  threadId      String            @map("thread_id") @db.Uuid
  senderRole    ChatMessageSender @map("sender_role")
  senderSubject String            @map("sender_subject") @db.VarChar(120)
  text          String?           @db.VarChar(2000)
  expiresAt     DateTime          @map("expires_at") @db.Timestamptz(6)
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  thread        ChatThread        @relation(fields: [threadId], references: [id], onDelete: Cascade)
  attachments   ChatAttachment[]

  @@index([threadId, createdAt], map: "idx_chat_message_thread_created")
  @@index([expiresAt], map: "idx_chat_message_expires")
  @@map("chat_message")
}

model ChatAttachment {
  id          String             @id @default(uuid()) @db.Uuid
  messageId   String             @map("message_id") @db.Uuid
  kind        ChatAttachmentKind
  fileName    String             @map("file_name") @db.VarChar(160)
  mimeType    String             @map("mime_type") @db.VarChar(120)
  sizeBytes   Int                @map("size_bytes")
  storagePath String             @map("storage_path") @db.VarChar(500)
  publicUrl   String?            @map("public_url") @db.VarChar(500)
  expiresAt   DateTime           @map("expires_at") @db.Timestamptz(6)
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  message     ChatMessage        @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, storagePath], map: "uq_chat_attachment_message_path")
  @@index([messageId], map: "idx_chat_attachment_message")
  @@index([expiresAt], map: "idx_chat_attachment_expires")
  @@map("chat_attachment")
}

model NotificationDeviceToken {
  id             String              @id @default(uuid()) @db.Uuid
  organizationId String              @map("organization_id") @db.Uuid
  membershipId   String?             @map("membership_id") @db.Uuid
  role           Role
  token          String              @unique @db.VarChar(255)
  platform       String              @db.VarChar(30)
  isActive       Boolean             @default(true) @map("is_active")
  lastSeenAt     DateTime?           @map("last_seen_at") @db.Timestamptz(6)
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  membership     OrganizationMember? @relation(fields: [membershipId], references: [id], onDelete: SetNull)

  @@index([organizationId, role, isActive], map: "idx_notification_device_org_role_active")
  @@index([membershipId, isActive], map: "idx_notification_device_membership_active")
  @@map("notification_device_token")
}

model NotificationPreference {
  id                String             @id @default(uuid()) @db.Uuid
  coachMembershipId String             @map("coach_membership_id") @db.Uuid
  topic             NotificationTopic
  enabled           Boolean            @default(true)
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  coachMembership   OrganizationMember @relation(fields: [coachMembershipId], references: [id], onDelete: Cascade)

  @@unique([coachMembershipId, topic], map: "uq_notification_pref_coach_topic")
  @@index([coachMembershipId], map: "idx_notification_pref_coach")
  @@map("notification_preference")
}

model NotificationEventLog {
  id                String              @id @default(uuid()) @db.Uuid
  organizationId    String              @map("organization_id") @db.Uuid
  coachMembershipId String?             @map("coach_membership_id") @db.Uuid
  clientId          String?             @map("client_id") @db.Uuid
  topic             NotificationTopic
  dedupeKey         String?             @unique @map("dedupe_key") @db.VarChar(180)
  payloadJson       Json?               @map("payload_json")
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  coachMembership   OrganizationMember? @relation(fields: [coachMembershipId], references: [id], onDelete: SetNull)
  client            Client?             @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([organizationId, topic, createdAt], map: "idx_notification_event_org_topic_created")
  @@index([coachMembershipId, topic, createdAt], map: "idx_notification_event_coach_topic_created")
  @@index([clientId, topic, createdAt], map: "idx_notification_event_client_topic_created")
  @@map("notification_event_log")
}
