model SessionInstance {
  id                  String              @id @default(uuid()) @db.Uuid
  organizationId      String              @map("organization_id") @db.Uuid
  coachMembershipId   String              @map("coach_membership_id") @db.Uuid
  clientId            String              @map("client_id") @db.Uuid
  sourceTemplateId    String              @map("source_template_id") @db.Uuid
  sourceTemplateVersion Int               @map("source_template_version")
  sessionDate         DateTime            @map("session_date") @db.Date
  startedAt           DateTime?           @map("started_at") @db.Timestamptz(6)
  finishedAt          DateTime?           @map("finished_at") @db.Timestamptz(6)
  isCompleted         Boolean             @default(false) @map("is_completed")
  isIncomplete        Boolean             @default(false) @map("is_incomplete")
  finishComment       String?             @map("finish_comment")
  status              SessionStatus       @default(PENDING)
  archivedAt          DateTime?           @map("archived_at") @db.Timestamptz(6)
  createdBy           String              @map("created_by") @db.Uuid
  updatedBy           String              @map("updated_by") @db.Uuid
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  coachMembership     OrganizationMember  @relation(fields: [coachMembershipId], references: [id], onDelete: Restrict)
  client              Client              @relation(fields: [clientId], references: [id], onDelete: Restrict)
  template            PlanTemplate        @relation(fields: [sourceTemplateId], references: [id], onDelete: Restrict)
  items               SessionStrengthItem[]
  cardioBlocks        SessionCardioBlock[]
  logs                SetLog[]
  intervalLogs        IntervalLog[]
  incidents           Incident[]
  weeklyReports       WeeklyReport[]

  @@unique([clientId, sessionDate], map: "uq_session_client_date")
  @@index([coachMembershipId, sessionDate], map: "idx_session_coach_date")
  @@index([organizationId, sessionDate], map: "idx_session_org_date")
  @@map("session_instance")
}

model SessionStrengthItem {
