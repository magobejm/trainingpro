generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  COACH
  CLIENT
}

enum LibraryItemScope {
  GLOBAL
  COACH
}

enum TemplateKind {
  STRENGTH
  CARDIO
  ROUTINE
}

enum FieldMode {
  HIDDEN
  COACH_INPUT
  CLIENT_INPUT
}

enum ExerciseGroupType {
  CIRCUIT
  SUPERSET
}

enum SessionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  REVIEWED
  CLOSED
}

enum IncidentActionType {
  ALERTED
  REVIEWED
  RESPONDED
  TAGGED
  ADJUSTMENT_DRAFTED
}

enum ChatMessageSender {
  COACH
  CLIENT
}

enum ChatAttachmentKind {
  IMAGE
  AUDIO
  PDF
}

enum NotificationTopic {
  SESSION_COMPLETED
  INCIDENT_CRITICAL
  CLIENT_INACTIVE_3D
  ADHERENCE_LOW_WEEKLY
  CLIENT_REMINDER
}

model Organization {
  id                       String                    @id @default(uuid()) @db.Uuid
  name                     String                    @db.VarChar(120)
  createdAt                DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  members                  OrganizationMember[]
  subscription             OrganizationSubscription?
  clients                  Client[]
  exercises                Exercise[]
  cardioMethods            CardioMethod[]
  foods                    Food[]
  plioExercises            PlioExercise[]
  mobilityExercises        MobilityExercise[]
  isometricExercises       IsometricExercise[]
  sports                   Sport[]
  planTemplates            PlanTemplate[]
  warmupTemplates          WarmupTemplate[]
  sessions                 SessionInstance[]
  incidents                Incident[]
  weeklyReports            WeeklyReport[]
  chatThreads              ChatThread[]
  notificationDeviceTokens NotificationDeviceToken[]
  notificationEventLogs    NotificationEventLog[]

  @@map("organization")
}

model User {
  id          String               @id @default(uuid()) @db.Uuid
  email       String               @unique @db.VarChar(320)
  supabaseUid String               @unique @map("supabase_uid") @db.Uuid
  isActive    Boolean              @default(true) @map("is_active")
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  memberships OrganizationMember[]

  @@map("user_account")
}

model OrganizationMember {
  id                       String                    @id @default(uuid()) @db.Uuid
  organizationId           String                    @map("organization_id") @db.Uuid
  userId                   String                    @map("user_id") @db.Uuid
  role                     Role
  isActive                 Boolean                   @default(true) @map("is_active")
  archivedAt               DateTime?                 @map("archived_at") @db.Timestamptz(6)
  createdAt                DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization             Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                     User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  managedClients           Client[]                  @relation("coach_managed_clients")
  exercises                Exercise[]                @relation("coach_exercises")
  cardioMethods            CardioMethod[]            @relation("coach_cardio_methods")
  foods                    Food[]                    @relation("coach_foods")
  plioExercises            PlioExercise[]            @relation("coach_plio_exercises")
  mobilityExercises        MobilityExercise[]        @relation("coach_mobility_exercises")
  isometricExercises       IsometricExercise[]       @relation("coach_isometric_exercises")
  sports                   Sport[]                   @relation("coach_sports")
  planTemplates            PlanTemplate[]            @relation("coach_plan_templates")
  warmupTemplates          WarmupTemplate[]          @relation("coach_warmup_templates")
  sessions                 SessionInstance[]
  incidents                Incident[]
  weeklyReports            WeeklyReport[]
  chatThreads              ChatThread[]              @relation("coach_chat_threads")
  notificationDeviceTokens NotificationDeviceToken[]
  notificationPreferences  NotificationPreference[]
  notificationEventLogs    NotificationEventLog[]

  @@unique([organizationId, userId, role], map: "uq_org_user_role")
  @@index([organizationId, role], map: "idx_org_member_org_role")
  @@index([userId], map: "idx_org_member_user")
  @@map("organization_member")
}

model OrganizationSubscription {
  id                String       @id @default(uuid()) @db.Uuid
  organizationId    String       @unique @map("organization_id") @db.Uuid
  clientLimit       Int          @default(0) @map("client_limit")
  activeClientCount Int          @default(0) @map("active_client_count")
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_subscription")
}

model Client {
  id                    String                    @id @default(uuid()) @db.Uuid
  organizationId        String                    @map("organization_id") @db.Uuid
  coachMembershipId     String                    @map("coach_membership_id") @db.Uuid
  email                 String                    @db.VarChar(320)
  avatarUrl             String?                   @map("avatar_url") @db.VarChar(500)
  firstName             String                    @map("first_name") @db.VarChar(80)
  lastName              String                    @map("last_name") @db.VarChar(80)
  objectiveId           String                    @map("objective_id") @db.Uuid
  trainingPlanId        String?                   @map("training_plan_id") @db.Uuid
  notes                 String?
  considerations        String?
  phone                 String?                   @db.VarChar(30)
  sex                   String?                   @db.VarChar(30)
  waistCm               Int?                      @map("waist_cm")
  hipCm                 Int?                      @map("hip_cm")
  fcMax                 Int?                      @map("fc_max")
  fcRest                Int?                      @map("fc_rest")
  fitnessLevel          String?                   @map("fitness_level") @db.VarChar(30)
  secondaryObjectives   String[]                  @default([]) @map("secondary_objectives")
  injuries              String?
  allergies             String?
  birthDate             DateTime?                 @map("birth_date") @db.Date
  heightCm              Int?                      @map("height_cm")
  weightKg              Decimal?                  @map("weight_kg") @db.Decimal(6, 2)
  createdBy             String                    @map("created_by") @db.Uuid
  updatedBy             String                    @map("updated_by") @db.Uuid
  archivedBy            String?                   @map("archived_by") @db.Uuid
  archivedAt            DateTime?                 @map("archived_at") @db.Timestamptz(6)
  createdAt             DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization          Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  coachMembership       OrganizationMember        @relation("coach_managed_clients", fields: [coachMembershipId], references: [id], onDelete: Restrict)
  objectiveRef          ClientObjective           @relation(fields: [objectiveId], references: [id], onDelete: Restrict)
  trainingPlan          PlanTemplate?             @relation(fields: [trainingPlanId], references: [id], onDelete: SetNull)
  managementSections    ClientManagementSection[]
  progressPhotos        ClientProgressPhoto[]
  sessions              SessionInstance[]
  incidents             Incident[]
  weeklyReports         WeeklyReport[]
  chatThreads           ChatThread[]              @relation("client_chat_threads")
  notificationEventLogs NotificationEventLog[]

  @@index([organizationId, archivedAt], map: "idx_client_org_archived")
  @@index([coachMembershipId, archivedAt], map: "idx_client_coach_archived")
  @@index([objectiveId], map: "idx_client_objective")
  @@index([trainingPlanId], map: "idx_client_training_plan")
  @@index([email], map: "idx_client_email")
  @@map("client")
}

model ClientManagementSection {
  id        String   @id @default(uuid()) @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  code      String   @db.VarChar(40)
  sortOrder Int      @default(0) @map("sort_order")
  archived  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, code], map: "uq_client_management_section_client_code")
  @@index([clientId, archived, sortOrder], map: "idx_client_management_section_lookup")
  @@map("client_management_section")
}

model ClientProgressPhoto {
  id        String   @id @default(uuid()) @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  imageUrl  String   @map("image_url") @db.VarChar(500)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, archived, createdAt], map: "idx_client_progress_photo_client_archived_created")
  @@map("client_progress_photo")
}

model ClientObjective {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(80)
  label     String   @unique @db.VarChar(120)
  sortOrder Int      @default(0) @map("sort_order")
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  clients   Client[]

  @@index([sortOrder], map: "idx_client_objective_sort")
  @@index([isDefault], map: "idx_client_objective_default")
  @@map("client_objective")
}

model RoutineObjective {
  id               String                  @id @default(uuid()) @db.Uuid
  code             String                  @unique @db.VarChar(80)
  label            String                  @unique @db.VarChar(120)
  sortOrder        Int                     @default(0) @map("sort_order")
  isDefault        Boolean                 @default(false) @map("is_default")
  createdAt        DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  routineTemplates PlanTemplateObjective[]

  @@index([sortOrder], map: "idx_routine_objective_sort")
  @@index([isDefault], map: "idx_routine_objective_default")
  @@map("routine_objective")
}

model ExerciseMuscleGroup {
  id          String                          @id @default(uuid()) @db.Uuid
  code        String                          @unique @db.VarChar(80)
  label       String                          @unique @db.VarChar(120)
  sortOrder   Int                             @default(0) @map("sort_order")
  isDefault   Boolean                         @default(false) @map("is_default")
  createdAt   DateTime                        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime                        @updatedAt @map("updated_at") @db.Timestamptz(6)
  assignments ExerciseMuscleGroupAssignment[]

  @@index([sortOrder], map: "idx_exercise_muscle_group_sort")
  @@index([isDefault], map: "idx_exercise_muscle_group_default")
  @@map("exercise_muscle_group")
}

model CardioMethodType {
  id            String         @id @default(uuid()) @db.Uuid
  code          String         @unique @db.VarChar(80)
  label         String         @unique @db.VarChar(120)
  sortOrder     Int            @default(0) @map("sort_order")
  isDefault     Boolean        @default(false) @map("is_default")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  cardioMethods CardioMethod[]

  @@index([sortOrder], map: "idx_cardio_method_type_sort")
  @@index([isDefault], map: "idx_cardio_method_type_default")
  @@map("cardio_method_type")
}

model ExerciseEquipment {
  id            String         @id @default(uuid()) @db.Uuid
  code          String         @unique @db.VarChar(80)
  label         String         @unique @db.VarChar(120)
  sortOrder     Int            @default(0) @map("sort_order")
  isDefault     Boolean        @default(false) @map("is_default")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  exercises           Exercise[]
  cardioMethods       CardioMethod[]
  plioExercises       PlioExercise[]
  isometricExercises  IsometricExercise[]
  mobilityExercises   MobilityExercise[]  @relation("mobility_equipment")
  sports              Sport[]             @relation("sport_equipment")

  @@index([sortOrder], map: "idx_exercise_equipment_sort")
  @@index([isDefault], map: "idx_exercise_equipment_default")
  @@map("exercise_equipment")
}

model PlioTypeRef {
  id            String         @id @default(uuid()) @db.Uuid
  code          String         @unique @db.VarChar(80)
  label         String         @unique @db.VarChar(120)
  sortOrder     Int            @default(0) @map("sort_order")
  isDefault     Boolean        @default(false) @map("is_default")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  plioExercises PlioExercise[]

  @@index([sortOrder], map: "idx_plio_type_sort")
  @@index([isDefault], map: "idx_plio_type_default")
  @@map("plio_type")
}

model MobilityTypeRef {
  id              String           @id @default(uuid()) @db.Uuid
  code            String           @unique @db.VarChar(80)
  label           String           @unique @db.VarChar(120)
  sortOrder       Int              @default(0) @map("sort_order")
  isDefault       Boolean          @default(false) @map("is_default")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  mobilityExercises MobilityExercise[]

  @@index([sortOrder], map: "idx_mobility_type_sort")
  @@index([isDefault], map: "idx_mobility_type_default")
  @@map("mobility_type")
}

model IsometricTypeRef {
  id                  String              @id @default(uuid()) @db.Uuid
  code                String              @unique @db.VarChar(80)
  label               String              @unique @db.VarChar(120)
  sortOrder           Int                 @default(0) @map("sort_order")
  isDefault           Boolean             @default(false) @map("is_default")
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  isometricExercises  IsometricExercise[]

  @@index([sortOrder], map: "idx_isometric_type_sort")
  @@index([isDefault], map: "idx_isometric_type_default")
  @@map("isometric_type")
}

model IsometricExercise {
  id                  String             @id @default(uuid()) @db.Uuid
  scope               LibraryItemScope
  organizationId      String?            @map("organization_id") @db.Uuid
  coachMembershipId   String?            @map("coach_membership_id") @db.Uuid
  name                String             @db.VarChar(120)
  isometricTypeId     String?            @map("isometric_type_id") @db.Uuid
  isometricType       String?            @map("isometric_type") @db.VarChar(30)
  equipmentId         String?            @map("equipment_id") @db.Uuid
  equipment           String?            @db.VarChar(120)
  movementPatternId   String?            @map("movement_pattern_id") @db.Uuid
  anatomicalPlaneId   String?            @map("anatomical_plane_id") @db.Uuid
  description         String?
  coachInstructions   String?            @map("coach_instructions")
  notes               String?
  youtubeUrl          String?            @map("youtube_url") @db.VarChar(500)
  mediaUrl            String?            @map("media_url") @db.VarChar(500)
  mediaType           String?            @map("media_type") @db.VarChar(40)
  createdBy           String?            @map("created_by") @db.Uuid
  updatedBy           String?            @map("updated_by") @db.Uuid
  archivedAt          DateTime?          @map("archived_at") @db.Timestamptz(6)
  createdAt           DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization           Organization?        @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  coachMembership        OrganizationMember?  @relation("coach_isometric_exercises", fields: [coachMembershipId], references: [id], onDelete: SetNull)
  isometricTypeRef       IsometricTypeRef?    @relation(fields: [isometricTypeId], references: [id], onDelete: SetNull)
  equipmentRef           ExerciseEquipment?   @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  movementPatternRef     MovementPattern?     @relation(fields: [movementPatternId], references: [id], onDelete: SetNull)
  anatomicalPlaneRef     AnatomicalPlane?     @relation(fields: [anatomicalPlaneId], references: [id], onDelete: SetNull)
  planIsometricBlocks    PlanIsometricBlock[]

  @@index([scope, archivedAt], map: "idx_isometric_scope_archived")
  @@index([coachMembershipId, archivedAt], map: "idx_isometric_coach_archived")
  @@index([isometricTypeId], map: "idx_isometric_type_fk")
  @@index([equipmentId], map: "idx_isometric_equipment")
  @@index([movementPatternId], map: "idx_isometric_movement_pattern")
  @@index([anatomicalPlaneId], map: "idx_isometric_anatomical_plane")
  @@map("isometric_exercise")
}

model SportTypeRef {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(80)
  label     String   @unique @db.VarChar(120)
  sortOrder Int      @default(0) @map("sort_order")
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  sports    Sport[]

  @@index([sortOrder], map: "idx_sport_type_sort")
  @@index([isDefault], map: "idx_sport_type_default")
  @@map("sport_type")
}

model MovementPattern {
  id        String     @id @default(uuid()) @db.Uuid
  code      String     @unique @db.VarChar(80)
  label     String     @unique @db.VarChar(120)
  sortOrder Int        @default(0) @map("sort_order")
  isDefault Boolean    @default(false) @map("is_default")
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  exercises          Exercise[]
  cardioMethods      CardioMethod[]
  plioExercises      PlioExercise[]
  mobilityExercises  MobilityExercise[]
  isometricExercises IsometricExercise[]
  sports             Sport[]

  @@index([sortOrder], map: "idx_movement_pattern_sort")
  @@index([isDefault], map: "idx_movement_pattern_default")
  @@map("movement_pattern")
}

model AnatomicalPlane {
  id        String     @id @default(uuid()) @db.Uuid
  code      String     @unique @db.VarChar(80)
  label     String     @unique @db.VarChar(120)
  sortOrder Int        @default(0) @map("sort_order")
  isDefault Boolean    @default(false) @map("is_default")
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  exercises          Exercise[]
  cardioMethods      CardioMethod[]
  plioExercises      PlioExercise[]
  mobilityExercises  MobilityExercise[]
  isometricExercises IsometricExercise[]
  sports             Sport[]

  @@index([sortOrder], map: "idx_anatomical_plane_sort")
  @@index([isDefault], map: "idx_anatomical_plane_default")
  @@map("anatomical_plane")
}

model ExerciseMuscleGroupAssignment {
  exerciseId    String              @map("exercise_id") @db.Uuid
  muscleGroupId String              @map("muscle_group_id") @db.Uuid
  exercise      Exercise            @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  muscleGroup   ExerciseMuscleGroup @relation(fields: [muscleGroupId], references: [id], onDelete: Cascade)

  @@id([exerciseId, muscleGroupId])
  @@index([muscleGroupId], map: "idx_emga_muscle_group")
  @@map("exercise_muscle_group_assignment")
}

model Exercise {
  id                    String                          @id @default(uuid()) @db.Uuid
  scope                 LibraryItemScope
  organizationId        String?                         @map("organization_id") @db.Uuid
  coachMembershipId     String?                         @map("coach_membership_id") @db.Uuid
  name                  String                          @db.VarChar(120)
  equipmentId           String?                         @map("equipment_id") @db.Uuid
  equipment             String?                         @db.VarChar(80)
  instructions          String?
  coachInstructions     String?                         @map("coach_instructions")
  mediaUrl              String?                         @map("media_url") @db.VarChar(500)
  mediaType             String?                         @map("media_type") @db.VarChar(40)
  youtubeUrl            String?                         @map("youtube_url") @db.VarChar(500)
  movementPatternId     String?                         @map("movement_pattern_id") @db.Uuid
  anatomicalPlaneId     String?                         @map("anatomical_plane_id") @db.Uuid
  createdBy             String?                         @map("created_by") @db.Uuid
  updatedBy             String?                         @map("updated_by") @db.Uuid
  archivedAt            DateTime?                       @map("archived_at") @db.Timestamptz(6)
  createdAt             DateTime                        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                        @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization          Organization?                   @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  coachMembership       OrganizationMember?             @relation("coach_exercises", fields: [coachMembershipId], references: [id], onDelete: SetNull)
  equipmentRef          ExerciseEquipment?              @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  movementPatternRef    MovementPattern?                @relation(fields: [movementPatternId], references: [id], onDelete: SetNull)
  anatomicalPlaneRef    AnatomicalPlane?                @relation(fields: [anatomicalPlaneId], references: [id], onDelete: SetNull)
  muscleGroups          ExerciseMuscleGroupAssignment[]
  planStrengthExercises PlanStrengthExercise[]
  warmupTemplateItems   WarmupTemplateItem[]

  @@index([scope, archivedAt], map: "idx_exercise_scope_archived")
  @@index([coachMembershipId, archivedAt], map: "idx_exercise_coach_archived")
  @@index([equipmentId], map: "idx_exercise_equipment")
  @@index([movementPatternId], map: "idx_exercise_movement_pattern")
  @@index([anatomicalPlaneId], map: "idx_exercise_anatomical_plane")
  @@map("exercise")
}

model CardioMethod {
  id                  String               @id @default(uuid()) @db.Uuid
  scope               LibraryItemScope
  organizationId      String?              @map("organization_id") @db.Uuid
  coachMembershipId   String?              @map("coach_membership_id") @db.Uuid
  name                String               @db.VarChar(120)
  methodTypeId        String               @map("method_type_id") @db.Uuid
  equipmentId         String?              @map("equipment_id") @db.Uuid
  description         String?
  coachInstructions   String?              @map("coach_instructions")
  equipment           String?              @db.VarChar(120)
  mediaUrl            String?              @map("media_url") @db.VarChar(500)
  mediaType           String?              @map("media_type") @db.VarChar(40)
  youtubeUrl          String?              @map("youtube_url") @db.VarChar(500)
  createdBy           String?              @map("created_by") @db.Uuid
  updatedBy           String?              @map("updated_by") @db.Uuid
  archivedAt          DateTime?            @map("archived_at") @db.Timestamptz(6)
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization        Organization?        @relation(fields: [organizationId], references: [id], onDelete: SetNull)
