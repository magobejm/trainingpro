generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  COACH
  CLIENT
}

enum LibraryItemScope {
  GLOBAL
  COACH
}

enum TemplateKind {
  STRENGTH
  CARDIO
  ROUTINE
}

enum FieldMode {
  HIDDEN
  COACH_INPUT
  CLIENT_INPUT
}

enum SessionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  REVIEWED
  CLOSED
}

enum IncidentActionType {
  ALERTED
  REVIEWED
  RESPONDED
  TAGGED
  ADJUSTMENT_DRAFTED
}

enum ChatMessageSender {
  COACH
  CLIENT
}

enum ChatAttachmentKind {
  IMAGE
  AUDIO
  PDF
}

enum NotificationTopic {
  SESSION_COMPLETED
  INCIDENT_CRITICAL
  CLIENT_INACTIVE_3D
  ADHERENCE_LOW_WEEKLY
  CLIENT_REMINDER
}

model Organization {
  id           String                   @id @default(uuid()) @db.Uuid
  name         String                   @db.VarChar(120)
  createdAt    DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  members      OrganizationMember[]
  subscription OrganizationSubscription?
  clients      Client[]
  exercises    Exercise[]
  cardioMethods CardioMethod[]
  foods        Food[]
  plioExercises PlioExercise[]
  warmupExercises WarmupExercise[]
  sports          Sport[]
  planTemplates PlanTemplate[]
  sessions     SessionInstance[]
  incidents    Incident[]
  weeklyReports WeeklyReport[]
  chatThreads  ChatThread[]
  notificationDeviceTokens NotificationDeviceToken[]
  notificationEventLogs NotificationEventLog[]

  @@map("organization")
}

model User {
  id          String               @id @default(uuid()) @db.Uuid
  email       String               @unique @db.VarChar(320)
  supabaseUid String               @unique @map("supabase_uid") @db.Uuid
  isActive    Boolean              @default(true) @map("is_active")
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  memberships OrganizationMember[]

  @@map("user_account")
}

model OrganizationMember {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  role           Role
  isActive       Boolean      @default(true) @map("is_active")
  archivedAt     DateTime?    @map("archived_at") @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  managedClients Client[]     @relation("coach_managed_clients")
  exercises      Exercise[]   @relation("coach_exercises")
  cardioMethods  CardioMethod[] @relation("coach_cardio_methods")
  foods          Food[]       @relation("coach_foods")
  plioExercises  PlioExercise[] @relation("coach_plio_exercises")
  warmupExercises WarmupExercise[] @relation("coach_warmup_exercises")
  sports          Sport[]       @relation("coach_sports")
  planTemplates  PlanTemplate[] @relation("coach_plan_templates")
  sessions       SessionInstance[]
  incidents      Incident[]
  weeklyReports  WeeklyReport[]
  chatThreads    ChatThread[]         @relation("coach_chat_threads")
  notificationDeviceTokens NotificationDeviceToken[]
  notificationPreferences NotificationPreference[]
  notificationEventLogs NotificationEventLog[]

  @@unique([organizationId, userId, role], map: "uq_org_user_role")
  @@index([organizationId, role], map: "idx_org_member_org_role")
  @@index([userId], map: "idx_org_member_user")
  @@map("organization_member")
}

model OrganizationSubscription {
  id                String       @id @default(uuid()) @db.Uuid
  organizationId    String       @unique @map("organization_id") @db.Uuid
  clientLimit       Int          @default(0) @map("client_limit")
  activeClientCount Int          @default(0) @map("active_client_count")
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_subscription")
}

model Client {
  id                String             @id @default(uuid()) @db.Uuid
  organizationId    String             @map("organization_id") @db.Uuid
  coachMembershipId String             @map("coach_membership_id") @db.Uuid
  email             String             @db.VarChar(320)
  avatarUrl         String?            @map("avatar_url") @db.VarChar(500)
  firstName         String             @map("first_name") @db.VarChar(80)
  lastName          String             @map("last_name") @db.VarChar(80)
  objectiveId       String             @map("objective_id") @db.Uuid
  notes             String?
  phone             String?            @db.VarChar(30)
  sex               String?            @db.VarChar(30)
  birthDate         DateTime?          @map("birth_date") @db.Date
  heightCm          Int?               @map("height_cm")
  weightKg          Decimal?           @map("weight_kg") @db.Decimal(6, 2)
  createdBy         String             @map("created_by") @db.Uuid
  updatedBy         String             @map("updated_by") @db.Uuid
  archivedBy        String?            @map("archived_by") @db.Uuid
  archivedAt        DateTime?          @map("archived_at") @db.Timestamptz(6)
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  coachMembership   OrganizationMember @relation("coach_managed_clients", fields: [coachMembershipId], references: [id], onDelete: Restrict)
  objectiveRef      ClientObjective    @relation(fields: [objectiveId], references: [id], onDelete: Restrict)
  sessions          SessionInstance[]
  incidents         Incident[]
  weeklyReports     WeeklyReport[]
  chatThreads       ChatThread[]      @relation("client_chat_threads")
  notificationEventLogs NotificationEventLog[]

  @@index([organizationId, archivedAt], map: "idx_client_org_archived")
  @@index([coachMembershipId, archivedAt], map: "idx_client_coach_archived")
  @@index([objectiveId], map: "idx_client_objective")
  @@index([email], map: "idx_client_email")
  @@map("client")
}

model ClientObjective {
  id         String   @id @default(uuid()) @db.Uuid
  code       String   @unique @db.VarChar(80)
  label      String   @unique @db.VarChar(120)
  sortOrder  Int      @default(0) @map("sort_order")
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  clients    Client[]

  @@index([sortOrder], map: "idx_client_objective_sort")
  @@index([isDefault], map: "idx_client_objective_default")
  @@map("client_objective")
}

model ExerciseMuscleGroup {
  id         String   @id @default(uuid()) @db.Uuid
  code       String   @unique @db.VarChar(80)
  label      String   @unique @db.VarChar(120)
  sortOrder  Int      @default(0) @map("sort_order")
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  exercises  Exercise[]

  @@index([sortOrder], map: "idx_exercise_muscle_group_sort")
  @@index([isDefault], map: "idx_exercise_muscle_group_default")
  @@map("exercise_muscle_group")
}

model CardioMethodType {
  id            String         @id @default(uuid()) @db.Uuid
  code          String         @unique @db.VarChar(80)
  label         String         @unique @db.VarChar(120)
  sortOrder     Int            @default(0) @map("sort_order")
  isDefault     Boolean        @default(false) @map("is_default")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  cardioMethods CardioMethod[]

  @@index([sortOrder], map: "idx_cardio_method_type_sort")
  @@index([isDefault], map: "idx_cardio_method_type_default")
  @@map("cardio_method_type")
}

model Exercise {
  id                String              @id @default(uuid()) @db.Uuid
  scope             LibraryItemScope
  organizationId    String?             @map("organization_id") @db.Uuid
  coachMembershipId String?             @map("coach_membership_id") @db.Uuid
  name              String              @db.VarChar(120)
  muscleGroupId     String              @map("muscle_group_id") @db.Uuid
  equipment         String?             @db.VarChar(80)
  instructions      String?
  mediaUrl          String?             @map("media_url") @db.VarChar(500)
  mediaType         String?             @map("media_type") @db.VarChar(40)
  youtubeUrl        String?             @map("youtube_url") @db.VarChar(500)
  createdBy         String?             @map("created_by") @db.Uuid
  updatedBy         String?             @map("updated_by") @db.Uuid
  archivedAt        DateTime?           @map("archived_at") @db.Timestamptz(6)
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization      Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  coachMembership   OrganizationMember? @relation("coach_exercises", fields: [coachMembershipId], references: [id], onDelete: SetNull)
  muscleGroupRef    ExerciseMuscleGroup @relation(fields: [muscleGroupId], references: [id], onDelete: Restrict)
  planStrengthExercises PlanStrengthExercise[]

  @@index([scope, archivedAt], map: "idx_exercise_scope_archived")
  @@index([coachMembershipId, archivedAt], map: "idx_exercise_coach_archived")
  @@index([muscleGroupId], map: "idx_exercise_muscle_group")
  @@map("exercise")
}

model CardioMethod {
  id                String              @id @default(uuid()) @db.Uuid
  scope             LibraryItemScope
  organizationId    String?             @map("organization_id") @db.Uuid
  coachMembershipId String?             @map("coach_membership_id") @db.Uuid
  name              String              @db.VarChar(120)
  methodTypeId      String              @map("method_type_id") @db.Uuid
  description       String?
  mediaUrl          String?             @map("media_url") @db.VarChar(500)
  mediaType         String?             @map("media_type") @db.VarChar(40)
  youtubeUrl        String?             @map("youtube_url") @db.VarChar(500)
  createdBy         String?             @map("created_by") @db.Uuid
  updatedBy         String?             @map("updated_by") @db.Uuid
  archivedAt        DateTime?           @map("archived_at") @db.Timestamptz(6)
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization      Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  coachMembership   OrganizationMember? @relation("coach_cardio_methods", fields: [coachMembershipId], references: [id], onDelete: SetNull)
  methodTypeRef     CardioMethodType    @relation(fields: [methodTypeId], references: [id], onDelete: Restrict)
  planCardioBlocks  PlanCardioBlock[]

  @@index([scope, archivedAt], map: "idx_cardio_scope_archived")
  @@index([coachMembershipId, archivedAt], map: "idx_cardio_coach_archived")
  @@index([methodTypeId], map: "idx_cardio_method_type")
  @@map("cardio_method")
}

model Food {
  id                String              @id @default(uuid()) @db.Uuid
  scope             LibraryItemScope
  organizationId    String?             @map("organization_id") @db.Uuid
  coachMembershipId String?             @map("coach_membership_id") @db.Uuid
  name              String              @db.VarChar(120)
  servingUnit       String?             @map("serving_unit") @db.VarChar(40)
  foodType          String?             @map("food_type") @db.VarChar(40)
  foodCategory      String?             @map("food_category") @db.VarChar(80)
  caloriesKcal      Int?                @map("calories_kcal")
  proteinG          Int?                @map("protein_g")
  carbsG            Int?                @map("carbs_g")
  fatG              Int?                @map("fat_g")
  notes             String?
  mediaUrl          String?             @map("media_url") @db.VarChar(500)
  mediaType         String?             @map("media_type") @db.VarChar(40)
  createdBy         String?             @map("created_by") @db.Uuid
  updatedBy         String?             @map("updated_by") @db.Uuid
  archivedAt        DateTime?           @map("archived_at") @db.Timestamptz(6)
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization      Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  coachMembership   OrganizationMember? @relation("coach_foods", fields: [coachMembershipId], references: [id], onDelete: SetNull)

  @@index([scope, archivedAt], map: "idx_food_scope_archived")
  @@index([coachMembershipId, archivedAt], map: "idx_food_coach_archived")
  @@map("food")
}

model PlioExercise {
  id                String              @id @default(uuid()) @db.Uuid
  scope             LibraryItemScope    @default(GLOBAL)
  organizationId    String?             @map("organization_id") @db.Uuid
  coachMembershipId String?             @map("coach_membership_id") @db.Uuid
  name              String              @db.VarChar(120)
  description       String?
  notes             String?
  youtubeUrl        String?             @map("youtube_url") @db.VarChar(500)
  mediaUrl          String?             @map("media_url") @db.VarChar(500)
  mediaType         String?             @map("media_type") @db.VarChar(40)
  archivedAt        DateTime?           @map("archived_at") @db.Timestamptz(6)
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization      Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  coachMembership   OrganizationMember? @relation("coach_plio_exercises", fields: [coachMembershipId], references: [id], onDelete: SetNull)
  planPlioBlocks    PlanPlioBlock[]

  @@index([scope, archivedAt], map: "idx_plio_scope_archived")
  @@index([coachMembershipId, archivedAt], map: "idx_plio_coach_archived")
  @@map("plio_exercise")
}

model WarmupExercise {
  id                String              @id @default(uuid()) @db.Uuid
  scope             LibraryItemScope    @default(GLOBAL)
  organizationId    String?             @map("organization_id") @db.Uuid
  coachMembershipId String?             @map("coach_membership_id") @db.Uuid
  name              String              @db.VarChar(120)
  description       String?
  notes             String?
  youtubeUrl        String?             @map("youtube_url") @db.VarChar(500)
  mediaUrl          String?             @map("media_url") @db.VarChar(500)
  mediaType         String?             @map("media_type") @db.VarChar(40)
  archivedAt        DateTime?           @map("archived_at") @db.Timestamptz(6)
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization      Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  coachMembership   OrganizationMember? @relation("coach_warmup_exercises", fields: [coachMembershipId], references: [id], onDelete: SetNull)
  planWarmupBlocks  PlanWarmupBlock[]

  @@index([scope, archivedAt], map: "idx_warmup_scope_archived")
  @@index([coachMembershipId, archivedAt], map: "idx_warmup_coach_archived")
  @@map("warmup_exercise")
}

model Sport {
  id                String              @id @default(uuid()) @db.Uuid
  scope             LibraryItemScope    @default(GLOBAL)
  organizationId    String?             @map("organization_id") @db.Uuid
  coachMembershipId String?             @map("coach_membership_id") @db.Uuid
  name              String              @db.VarChar(120)
  icon              String              @db.VarChar(10)
  description       String?
  mediaUrl          String?             @map("media_url") @db.VarChar(500)
  archivedAt        DateTime?           @map("archived_at") @db.Timestamptz(6)
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization      Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  coachMembership   OrganizationMember? @relation("coach_sports", fields: [coachMembershipId], references: [id], onDelete: SetNull)
  planSportBlocks   PlanSportBlock[]

  @@index([scope, archivedAt], map: "idx_sport_scope_archived")
  @@index([coachMembershipId, archivedAt], map: "idx_sport_coach_archived")
  @@map("sport")
}



model PlanTemplate {
  id                String              @id @default(uuid()) @db.Uuid
  scope             LibraryItemScope    @default(COACH)
  organizationId    String?             @map("organization_id") @db.Uuid
  coachMembershipId String?             @map("coach_membership_id") @db.Uuid
  kind              TemplateKind        @default(STRENGTH)
  name              String              @db.VarChar(120)
  templateVersion   Int                 @default(1) @map("template_version")
  archivedAt        DateTime?           @map("archived_at") @db.Timestamptz(6)
  createdBy         String?             @map("created_by") @db.Uuid
  updatedBy         String?             @map("updated_by") @db.Uuid
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization      Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  coachMembership   OrganizationMember? @relation("coach_plan_templates", fields: [coachMembershipId], references: [id], onDelete: SetNull)
  days              PlanDay[]
  sessions          SessionInstance[]

  @@index([scope, archivedAt], map: "idx_plan_template_scope_archived")
  @@index([coachMembershipId, archivedAt], map: "idx_plan_template_coach_archived")
  @@index([organizationId, archivedAt], map: "idx_plan_template_org_archived")
  @@map("plan_template")
}

model PlanDay {
  id             String               @id @default(uuid()) @db.Uuid
  templateId     String               @map("template_id") @db.Uuid
  dayIndex       Int                  @map("day_index")
  title          String               @db.VarChar(120)
  archivedAt     DateTime?            @map("archived_at") @db.Timestamptz(6)
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  template       PlanTemplate         @relation(fields: [templateId], references: [id], onDelete: Cascade)
  exercises      PlanStrengthExercise[]
  cardioBlocks   PlanCardioBlock[]
  plioBlocks     PlanPlioBlock[]
  warmupBlocks   PlanWarmupBlock[]
  sportBlocks    PlanSportBlock[]

  @@index([templateId, archivedAt], map: "idx_plan_day_template_archived")
  @@unique([templateId, dayIndex], map: "uq_plan_day_template_index")
  @@map("plan_day")
}

model PlanStrengthExercise {
  id                    String             @id @default(uuid()) @db.Uuid
  dayId                 String             @map("day_id") @db.Uuid
  exerciseLibraryId     String?            @map("exercise_library_id") @db.Uuid
  sortOrder             Int                @default(0) @map("sort_order")
  displayName           String             @map("display_name") @db.VarChar(120)
  setsPlanned           Int?               @map("sets_planned")
  repsMin               Int?               @map("reps_min")
  repsMax               Int?               @map("reps_max")
  weightRangeMinKg      Decimal?           @map("weight_range_min_kg") @db.Decimal(6, 2)
  weightRangeMaxKg      Decimal?           @map("weight_range_max_kg") @db.Decimal(6, 2)
  perSetWeightRangesJson Json?             @map("per_set_weight_ranges_json")
  targetRpe             Int?               @map("target_rpe")
  targetRir             Int?               @map("target_rir")
  restSeconds           Int?               @default(0) @map("rest_seconds")
  notes                 String?
  archivedAt            DateTime?          @map("archived_at") @db.Timestamptz(6)
  createdAt             DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  day                   PlanDay            @relation(fields: [dayId], references: [id], onDelete: Cascade)
  libraryExercise       Exercise?          @relation(fields: [exerciseLibraryId], references: [id], onDelete: SetNull)
  fieldModes            FieldModeSetting[]

  @@index([dayId, archivedAt], map: "idx_plan_strength_day_archived")
  @@map("plan_strength_exercise")
}

model FieldModeSetting {
  id                     String               @id @default(uuid()) @db.Uuid
  planStrengthExerciseId String               @map("plan_strength_exercise_id") @db.Uuid
  fieldKey               String               @map("field_key") @db.VarChar(80)
  mode                   FieldMode            @default(COACH_INPUT)
  createdAt              DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  planStrengthExercise   PlanStrengthExercise @relation(fields: [planStrengthExerciseId], references: [id], onDelete: Cascade)

  @@unique([planStrengthExerciseId, fieldKey], map: "uq_field_mode_item_field")
  @@index([planStrengthExerciseId], map: "idx_field_mode_item")
  @@map("field_mode")
}

model PlanCardioBlock {
  id                    String                 @id @default(uuid()) @db.Uuid
  dayId                 String                 @map("day_id") @db.Uuid
  cardioMethodLibraryId String?                @map("cardio_method_library_id") @db.Uuid
  sortOrder             Int                    @default(0) @map("sort_order")
  displayName           String                 @map("display_name") @db.VarChar(120)
  roundsPlanned         Int                    @default(1) @map("rounds_planned")
  workSeconds           Int                    @map("work_seconds")
  restSeconds           Int                    @default(0) @map("rest_seconds")
  targetDistanceMeters  Int?                   @map("target_distance_meters")
  targetRpe             Int?                   @map("target_rpe")
  notes                 String?
  archivedAt            DateTime?              @map("archived_at") @db.Timestamptz(6)
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  day                   PlanDay                @relation(fields: [dayId], references: [id], onDelete: Cascade)
  libraryCardioMethod   CardioMethod?          @relation(fields: [cardioMethodLibraryId], references: [id], onDelete: SetNull)
  fieldModes            CardioFieldModeSetting[]

  @@index([dayId, archivedAt], map: "idx_plan_cardio_day_archived")
  @@map("plan_cardio_block")
}

model CardioFieldModeSetting {
  id                String          @id @default(uuid()) @db.Uuid
  planCardioBlockId String          @map("plan_cardio_block_id") @db.Uuid
  fieldKey          String          @map("field_key") @db.VarChar(80)
  mode              FieldMode       @default(COACH_INPUT)
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  planCardioBlock   PlanCardioBlock @relation(fields: [planCardioBlockId], references: [id], onDelete: Cascade)

  @@unique([planCardioBlockId, fieldKey], map: "uq_cardio_field_mode_item_field")
  @@index([planCardioBlockId], map: "idx_cardio_field_mode_item")
  @@map("cardio_field_mode")
}

model PlanPlioBlock {
  id                    String         @id @default(uuid()) @db.Uuid
  dayId                 String         @map("day_id") @db.Uuid
